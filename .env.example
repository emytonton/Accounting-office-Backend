NODE_ENV=development
PORT=3000
APP_NAME=Accounting HUB
APP_URL=http://localhost:3000
DATABASE_URL=postgresql://user:password@localhost:5432/accounting_hub
JWT_SECRET=change_me
JWT_EXPIRES_IN=30m

